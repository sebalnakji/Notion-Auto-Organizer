# Notion Auto Organizer 환경 설정
# API 키 및 설정값은 앱 실행 후 [설정] 화면에서 직접 입력하세요.

# ── 모델 설정 (선택, 미입력 시 기본값 사용) ──────────────────────────────────
OPENAI_MODEL=gpt-5.2
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-3.1-pro-preview

# (선택) 로그 레벨 조정이 필요한 경우만 사용
# LOG_LEVEL=INFO

# 실행방법
# 1. cd [path]
# 2. streamlit run src/main.py

# 기본 포트: 8502